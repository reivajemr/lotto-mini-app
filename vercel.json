{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "crons": [
    { "path": "/api/scraper", "schedule": "5 12 * * *" },
    { "path": "/api/scraper", "schedule": "5 13 * * *" },
    { "path": "/api/scraper", "schedule": "5 14 * * *" },
    { "path": "/api/scraper", "schedule": "5 15 * * *" },
    { "path": "/api/scraper", "schedule": "5 16 * * *" },
    { "path": "/api/scraper", "schedule": "5 17 * * *" },
    { "path": "/api/scraper", "schedule": "5 18 * * *" },
    { "path": "/api/scraper", "schedule": "5 19 * * *" },
    { "path": "/api/scraper", "schedule": "5 20 * * *" },
    { "path": "/api/scraper", "schedule": "5 21 * * *" },
    { "path": "/api/scraper", "schedule": "5 22 * * *" },
    { "path": "/api/scraper", "schedule": "5 23 * * *" }
  ],
  "functions": {
    "Api/user.mjs":    { "maxDuration": 30 },
    "Api/scraper.mjs": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/user",    "destination": "/api/user.mjs" },
    { "source": "/api/scraper", "destination": "/api/scraper.mjs" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
